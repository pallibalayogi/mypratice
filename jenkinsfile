pipeline {

    agent any

    parameters {

        choice(
            name: 'ENV',
            choices: ['DEV', 'QA', 'PROD'],
            description: 'Select Environment'
        )
    }

    environment {
        HOST = "petstore.octoperf.com"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'master',
                url: 'https://github.com/pallibalayogi/mypratice.git'
            }
        }

        stage('Set Environment') {
            steps {
                script {

                    echo "Selected ENV = ${params.ENV}"

                    if (params.ENV == "DEV") {
                        env.HOST = "petstore.octoperf.com"
                    }
                    else if (params.ENV == "QA") {
                        env.HOST = "jpetstore.aspectran.com"
                    }
                    else if (params.ENV == "PROD") {
                        env.HOST = "opensource-demo.orangehrmlive.com"
                    }
                    else {
                        // fallback safety (prevents null issue)
                        env.HOST = "petstore.octoperf.com"
                        echo "WARNING: ENV not selected, using default DEV"
                    }

                    echo "Running test on: ${env.HOST}"
                }
            }
        }

        stage('Run JMeter Test') {
            steps {

                bat """
                if exist report rmdir /s /q report
                if exist result.jtl del /f /q result.jtl

                jmeter -n ^
                -t petstorepratice.jmx ^
                -Jhost=%HOST% ^
                -l result.jtl ^
                -e -o report
                """
            }
        }

        stage('Archive Results') {
            steps {
                archiveArtifacts artifacts: 'result.jtl, report/**/*', fingerprint: true
            }
        }

        stage('Publish HTML Report') {
            steps {
                publishHTML([
                    reportDir: 'report',
                    reportFiles: 'index.html',
                    reportName: 'JMeter HTML Report',
                    allowMissing: false,
                    keepAll: true,
                    alwaysLinkToLastBuild: true
                ])
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS"
        }

        failure {
            echo "Pipeline FAILED"
        }
    }
}